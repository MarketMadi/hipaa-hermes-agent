# Dev droplet — copy to .env on the server (never commit)
HERMES_ENV=dev

# Audit: Postgres required for dev (encryption at rest via managed DB in prod)
AUDIT_BACKEND=postgres
DATABASE_URL=postgres://hermes:hermes@127.0.0.1:5433/hermes_audit
DATABASE_PATH=/var/lib/hermes/hipaa_hermes.db
ADMIN_SECRET=replace-with-24-char-random-string
AUDITOR_SECRET=replace-with-24-char-random-string

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=biomistral-hermes

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
LLM_DISABLED=0
LLM_FALLBACK_STUB=0

DEID_MODE=hybrid
DEID_NER_URL=http://127.0.0.1:3001
DEID_BLOCK_ON_HIGH_RISK=1

# Behind Caddy TLS proxy (Epic 2)
HERMES_BEHIND_PROXY=1
BIND_HOST=127.0.0.1
BIND_PORT=8090

# OIDC (Epic 3) — enable on dev droplet; see docs/OIDC.md
# OIDC_ENABLED=1
# OIDC_ISSUER=https://idp-dev.example.com/realms/hermes
# OIDC_AUDIENCE=hermes-api
# OIDC_OPERATOR_GROUPS=hermes-operator
# OIDC_AUDITOR_GROUPS=hermes-auditor
# OIDC_ALLOW_ROLE_KEY=1

# Set on droplet: public hostname for Caddy ACME (future Caddyfile.dev)
# HERMES_PUBLIC_HOST=hermes-dev.example.com
