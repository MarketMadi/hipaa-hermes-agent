# Production — inject via Vault / secrets manager; do not commit
HERMES_ENV=prod

DATABASE_PATH=/var/lib/hermes/hipaa_hermes.db
ADMIN_SECRET=from-vault
AUDITOR_SECRET=from-vault

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=biomistral-hermes

ANTHROPIC_API_KEY=
LLM_DISABLED=0
LLM_FALLBACK_STUB=0

DEID_MODE=hybrid
DEID_NER_URL=http://127.0.0.1:3001
DEID_BLOCK_ON_HIGH_RISK=1

HERMES_BEHIND_PROXY=1
BIND_HOST=127.0.0.1
BIND_PORT=8090

# HERMES_PUBLIC_HOST=hermes.example.com
