# Local dev only — never commit .env. Use a secrets manager in production.
DATABASE_PATH=data/hipaa_hermes.db
ADMIN_SECRET=change-me-operator
AUDITOR_SECRET=change-me-auditor

# LLM — on-prem by default (recommended for regulated environments)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b

# Optional cloud inference — only if you explicitly want Claude
# LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

LLM_DISABLED=0
# When LLM backend fails, return demo stub instead of error (default on; set 0 for real-only)
LLM_FALLBACK_STUB=1

BIND_HOST=0.0.0.0
BIND_PORT=8090
