# Local development — copy to .env
HERMES_ENV=local

# Audit: SQLite (default for local). For Postgres see docs/AUDIT_DB.md
DATABASE_PATH=data/hipaa_hermes.db
# AUDIT_BACKEND=sqlite
# DATABASE_URL=postgres://hermes:hermes@127.0.0.1:5433/hermes_audit
ADMIN_SECRET=change-me-operator
AUDITOR_SECRET=change-me-auditor

# BioMistral on-prem (default)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=biomistral-hermes

# Optional cloud inference
# LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

LLM_DISABLED=0
LLM_FALLBACK_STUB=1

DEID_MODE=rules
DEID_NER_URL=http://127.0.0.1:3001
DEID_BLOCK_ON_HIGH_RISK=0

# Plain HTTP on all interfaces (fine for laptop demos)
BIND_HOST=0.0.0.0
BIND_PORT=8090

# OIDC / SSO (Epic 3) — off by default; see docs/OIDC.md
# OIDC_ENABLED=0
# OIDC_ISSUER=http://127.0.0.1:8180/realms/hermes
# OIDC_AUDIENCE=hermes-api
# OIDC_JWKS_URL=
# OIDC_OPERATOR_GROUPS=hermes-operator
# OIDC_AUDITOR_GROUPS=hermes-auditor
# OIDC_ALLOW_ROLE_KEY=1

# Vault secrets (Epic 5) — optional local; see docs/VAULT.md
# ./scripts/setup-vault.sh && ./scripts/run-with-vault.sh
# VAULT_ENABLED=1

# Set both to enable local HTTPS via Caddy (https://localhost:8443)
# HERMES_BEHIND_PROXY=1
# BIND_HOST=127.0.0.1

# ---------------------------------------------------------------------------
# Full local stack (v4.3) — uncomment for Postgres + OIDC + hybrid de-ID
# See docs/LOCAL_STACK.md for setup scripts and verification.
# ---------------------------------------------------------------------------
# AUDIT_BACKEND=postgres
# DATABASE_URL=postgres://hermes:hermes@127.0.0.1:5433/hermes_audit
# DEID_MODE=hybrid
# DEID_BLOCK_ON_HIGH_RISK=1
# OIDC_ENABLED=1
# OIDC_ISSUER=http://127.0.0.1:8180/realms/hermes
# OIDC_AUDIENCE=hermes-api
# OIDC_ALLOW_ROLE_KEY=1
# Then: ./scripts/setup-postgres.sh && ./scripts/setup-keycloak.sh
#       ./scripts/setup-vault.sh && ./scripts/run-with-vault.sh
